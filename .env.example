# Supabase: use the POOLED connection (port 6543, pgbouncer) for runtime
# queries, and the DIRECT connection (port 5432) for migrations.
# Find both under Project Settings -> Database -> Connection string.
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

# Optional. If unset, the app still works correctly — Redis is only used as
# a throughput optimization (distributed lock + idempotency fast path), not
# for correctness. See src/lib/redis.ts.
# Example (Upstash): rediss://default:[PASSWORD]@[HOST]:6379
REDIS_URL=""

# Shared secret required by the cron sweep endpoint (Authorization: Bearer <secret>).
CRON_SECRET="change-me"
